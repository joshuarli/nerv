#!/usr/bin/env python3
"""
batch-wt — launch one tmux window per task in a jobs file.

Usage:
  batch-wt [options] <jobs-file>

Options:
  --model <model>          Model to pass to nerv (default: claude-sonnet-4-6)
  --thinking               Enable extended thinking
  --effort <level>         Effort level: off|low|medium|high|max
  --dry-run                Print tmux commands without running them
  -h, --help               Show this help

Jobs file format — tasks separated by lines containing only "---":

  Refactor the auth module to use OAuth2.
  Make sure to update all call sites.

  ---

  Add dark mode to the settings panel.

  ---

  Fix sidebar overlap on mobile.
"""

import re
import shlex
import subprocess
import sys
from dataclasses import dataclass, field
from typing import Optional


STOPWORDS = frozenset(
    "a an the and or but if in on at to for of with by from "
    "that this is are was be have has do does its it".split()
)


def slugify(text: str, max_chars: int = 50) -> str:
    """Turn the first line of a task description into a git-branch-safe slug."""
    first_line = text.strip().splitlines()[0]
    # Strip trailing sentence punctuation so "Fix the bug." doesn't end with a dot.
    first_line = re.sub(r"[.!?]+$", "", first_line)
    # Lowercase and replace non-alphanumeric runs with spaces.
    clean = re.sub(r"[^a-z0-9]+", " ", first_line.lower()).strip()
    words = []
    for word in clean.split():
        if len(words) >= 6:
            break
        if word not in STOPWORDS:
            words.append(word)
    slug = "-".join(words) if words else "task"
    # Hard cap at max_chars, not splitting mid-char (all ASCII here).
    if len(slug) > max_chars:
        slug = slug[:max_chars].rsplit("-", 1)[0] or slug[:max_chars]
    return slug


def window_name(slug: str, max_chars: int = 10) -> str:
    """Shorten a slug to fit a tmux window name."""
    if len(slug) <= max_chars:
        return slug
    trunc = slug[:max_chars]
    # Only walk back to last dash if we cut mid-word (next char isn't a dash).
    if slug[max_chars] != "-" and "-" in trunc:
        return trunc.rsplit("-", 1)[0]
    return trunc


def parse_tasks(text: str) -> list[str]:
    """Split a jobs file on --- separators, dropping blank tasks."""
    blocks = re.split(r"^\s*---\s*$", text, flags=re.MULTILINE)
    return [b.strip() for b in blocks if b.strip()]


@dataclass
class Args:
    jobs_file: str
    model: str = "claude-sonnet-4-6"
    thinking: bool = False
    effort: Optional[str] = None
    dry_run: bool = False


def parse_args(argv: list[str]) -> Args:
    args = Args(jobs_file="")
    i = 0
    while i < len(argv):
        a = argv[i]
        if a in ("-h", "--help"):
            print(__doc__)
            sys.exit(0)
        elif a == "--model":
            i += 1
            if i >= len(argv):
                sys.exit("--model requires a value")
            args.model = argv[i]
        elif a == "--thinking":
            args.thinking = True
        elif a == "--effort":
            i += 1
            if i >= len(argv):
                sys.exit("--effort requires a value")
            level = argv[i]
            if level not in ("off", "low", "medium", "high", "max"):
                sys.exit(f"--effort must be one of: off low medium high max (got {level!r})")
            args.effort = level
        elif a == "--dry-run":
            args.dry_run = True
        elif a.startswith("-"):
            sys.exit(f"Unknown option: {a}")
        else:
            if args.jobs_file:
                sys.exit("Too many positional arguments")
            args.jobs_file = a
        i += 1

    if not args.jobs_file:
        print(__doc__)
        sys.exit("Error: jobs file required")

    return args


def build_nerv_cmd(branch: str, task: str, args: Args) -> list[str]:
    cmd = ["nerv", "wt", branch, "--model", args.model, "--prompt", task]
    if args.thinking:
        cmd.append("--thinking")
    if args.effort and args.effort != "off":
        cmd.extend(["--effort", args.effort])
    return cmd


def main() -> None:
    args = parse_args(sys.argv[1:])

    try:
        text = open(args.jobs_file).read()
    except OSError as e:
        sys.exit(f"Cannot read {args.jobs_file!r}: {e}")

    tasks = parse_tasks(text)
    if not tasks:
        sys.exit(f"No tasks found in {args.jobs_file!r}")

    print(f"batch-wt: {len(tasks)} task(s) from {args.jobs_file!r}", flush=True)

    for i, task in enumerate(tasks):
        slug = slugify(task)
        # Deduplicate branch names if two tasks share the same slug.
        branch = slug if i == 0 else f"{slug}-{i + 1}"
        win = window_name(slug)
        nerv_cmd = build_nerv_cmd(branch, task, args)

        # tmux new-window -n <name> cmd arg arg ...
        # Pass each token separately so tmux execs the command directly.
        tmux_cmd = ["tmux", "new-window", "-n", win] + nerv_cmd

        display = shlex.join(nerv_cmd)
        if args.dry_run:
            print(f"  [{win}] {display}")
        else:
            print(f"  [{win}] {display}", flush=True)
            subprocess.run(tmux_cmd, check=True)


if __name__ == "__main__":
    main()
